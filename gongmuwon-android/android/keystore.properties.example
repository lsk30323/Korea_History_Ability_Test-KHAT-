# 릴리스 서명용 키스토어 설정 (로컬 빌드용)
# 이 파일을 복사해 같은 폴더에 keystore.properties 로 저장한 뒤 값을 채우세요.
#   cp keystore.properties.example keystore.properties
# keystore.properties 와 *.keystore/*.jks 파일은 .gitignore 에 의해 커밋되지 않습니다.
# 절대 깃에 올리지 마세요 (이 저장소는 공개 저장소입니다).

# .keystore 파일의 절대 경로 (예: /home/me/keys/release.keystore)
storeFile=/absolute/path/to/release.keystore
storePassword=여기에_키스토어_비밀번호
keyAlias=khat
keyPassword=여기에_키_비밀번호
